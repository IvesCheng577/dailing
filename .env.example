# 复制本文件为 .env，填写后本地开发使用
# 部署到 Railway 时，在 Dashboard → Variables 中设置这些变量

# 必填：Session 加密密钥，生产环境务必改为随机长字符串
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=请替换为随机字符串

# 可选：指定数据库文件目录（Railway 挂载持久卷时使用）
# DATA_DIR=/app/data

# 可选：指定上传图片目录（Railway 挂载持久卷时使用）
# UPLOAD_DIR=/app/public/uploads

# 可选：端口（Railway 会自动注入 PORT，通常不需要手动设置）
# PORT=3000

# 生产环境标识
NODE_ENV=production
